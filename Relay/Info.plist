<plist version="1.0">
<dict>
	<key>GiphyAPIKey</key>
	<string>$(GIPHY_API_KEY)</string>
	<key>NSCameraUsageDescription</key>
	<string>Relay uses the camera for video calls in Matrix rooms.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Relay uses the microphone for audio and video calls in Matrix rooms.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>OAuth Callback</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>io.github.subpop.relay</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>Matrix URI</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>matrix</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
